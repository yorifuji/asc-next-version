{
  "name": "asc-next-version",
  "version": "1.0.0",
  "description": "GitHub Action to determine next version and build number for App Store Connect",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build:clean && npm run build:compile",
    "build:clean": "rm -rf dist",
    "build:compile": "tsx build.ts",
    "build:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "verify": "npm run lint && npm run format:check && npm run test",
    "verify:fix": "npm run lint:fix && npm run format && npm run test",
    "precommit": "npm run verify",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run verify && npm run build",
    "version": "npm run verify && git add -A",
    "postversion": "git push && git push --tags",
    "ci-test": "vitest run",
    "all": "npm run lint && npm run format:check && npm run typecheck && npm run ci-test && npm run build"
  },
  "keywords": [
    "github-actions",
    "app-store-connect",
    "ios",
    "macos",
    "versioning",
    "build-number"
  ],
  "author": "yorifuji",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yorifuji/asc-next-version.git"
  },
  "bugs": {
    "url": "https://github.com/yorifuji/asc-next-version/issues"
  },
  "homepage": "https://github.com/yorifuji/asc-next-version#readme",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "jsonwebtoken": "9.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.1.8",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "files": [
    "dist/",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/yorifuji"
  },
  "overrides": {
    "flatted": "3.4.2"
  }
}
